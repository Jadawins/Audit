# Variables d'environnement requises pour auditms-api
# Copier ce fichier en .env et remplir les valeurs

# Azure App Registration (client_credentials pour /api/inbox-rules)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# SMTP Zimbra
SMTP_HOST=mail.auditms.fr
SMTP_PORT=587
SMTP_USER=no-reply@auditms.fr
SMTP_PASS=

# Destination des leads
LEAD_DEST=william@auditms.fr

# Webhook GitHub Actions (obligatoire — le serveur refuse de démarrer sans)
WEBHOOK_SECRET=

# Chemin du repo sur le VPS
APP_DIR=/var/www/auditms/app
